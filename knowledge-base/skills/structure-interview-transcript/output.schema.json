{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StructuredInterviewTranscriptPayload",
  "type": "object",
  "additionalProperties": false,
  "required": ["transcript_status", "transcript_summary", "turns", "open_questions"],
  "properties": {
    "transcript_status": { "type": "string", "enum": ["complete", "degraded", "needs_data"] },
    "transcript_summary": { "type": "string", "minLength": 1 },
    "turns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["turn_no", "speaker", "text"],
        "properties": {
          "turn_no": { "type": "integer", "minimum": 1 },
          "speaker": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "tags": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "open_questions": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}

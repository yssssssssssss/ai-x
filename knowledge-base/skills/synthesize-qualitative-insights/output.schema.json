{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QualitativeInsightSynthesisPayload",
  "type": "object",
  "additionalProperties": false,
  "required": ["themes", "insights", "open_questions"],
  "properties": {
    "themes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "summary", "evidence_refs"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "insights": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "open_questions": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}

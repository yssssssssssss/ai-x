# PostgreSQL 连接(V0 用本机 Homebrew PG,免 docker)
DATABASE_URL=postgres://localhost:5432/user_research_ai

# LLM 通道:mock=预置 fixture(单测/离线);gateway=京东内网真实网关(默认)
LLM_PROVIDER=gateway
# 内网网关(OpenAI 兼容);key 从安全渠道注入本机 .env,勿提交
LLM_GATEWAY_BASE_URL=http://llm-gw.jd.local/v1
LLM_GATEWAY_API_KEY=
LLM_GATEWAY_TIMEOUT_MS=90000
LLM_MODEL_NAME=GPT-5.4-joybuilder
LLM_MODEL_FALLBACKS=GPT-5.2-joybuilder,GPT-5-joybuilder
# 普通 429 的同模型退避和候选熔断冷却。配额 429、超时、网络错误与 5xx 会切换下一个候选。
LLM_RATE_LIMIT_BACKOFF_MS=5000
LLM_CIRCUIT_FAILURE_THRESHOLD=2
LLM_CIRCUIT_COOLDOWN_MS=30000
VLM_GATEWAY_BASE_URL=http://llm-gw.jd.local/v1
VLM_GATEWAY_API_KEY=
VLM_MODEL_NAME=GPT-5.4-joybuilder
VLM_MODEL_FALLBACKS=GPT-5.5-joybuilder,GPT-5-joybuilder
VLM_GATEWAY_TIMEOUT_MS=120000
# 视觉实验室复用文本网关的连接凭据，但始终使用上面的独立视觉候选链。
VLM_USE_TEXT_GATEWAY=true
LLM_MODEL_VERSION=v0

# Tool 通道:V0=fake(FakeO2Adapter);二期切 o2 真实 adapter
TOOL_ADAPTER=fake

# 运行期工作区根目录(大对象/中间文件不进 PG)
RUN_WORKSPACE_ROOT=./run-workspaces

# ai-spider-app 竞品检索 tool(ai-spider-search)连接配置
SPIDER_BASE_URL=http://localhost:8000
SPIDER_USERNAME=
SPIDER_PASSWORD=
SPIDER_TIMEOUT_MS=30000

# external-tools/*-lab 工具后端地址(rest_json adapter 从这里读 base_url)
# 本机默认端口见 scripts/start-labs.mjs;各工具无鉴权
AESTHETIC_QUANT_BASE_URL=http://127.0.0.1:8801
ATTENTION_ANALYSIS_BASE_URL=http://127.0.0.1:8802
EXPERIENCE_MODEL_BASE_URL=http://127.0.0.1:8803
VIRTUAL_USER_BASE_URL=http://127.0.0.1:8804
VISION_BRAND_BASE_URL=http://127.0.0.1:8805

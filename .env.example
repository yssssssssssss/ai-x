# PostgreSQL 连接(V0 用本机 Homebrew PG,免 docker)
DATABASE_URL=postgres://localhost:5432/user_research_ai

# LLM 通道:mock=预置 fixture(单测/离线);gateway=京东内网真实网关(默认)
LLM_PROVIDER=gateway
# 内网网关(OpenAI 兼容);key 从安全渠道注入本机 .env,勿提交
LLM_GATEWAY_BASE_URL=http://llm-gw.jd.local/v1
LLM_GATEWAY_API_KEY=
LLM_GATEWAY_TIMEOUT_MS=90000
LLM_MODEL_NAME=GPT-5.5-joybuilder
LLM_MODEL_VERSION=v0

# Tool 通道:V0=fake(FakeO2Adapter);二期切 o2 真实 adapter
TOOL_ADAPTER=fake

# 运行期工作区根目录(大对象/中间文件不进 PG)
RUN_WORKSPACE_ROOT=./run-workspaces

# ai-spider-app 竞品检索 tool(ai-spider-search)连接配置
SPIDER_BASE_URL=http://localhost:8000
SPIDER_USERNAME=
SPIDER_PASSWORD=
SPIDER_TIMEOUT_MS=30000

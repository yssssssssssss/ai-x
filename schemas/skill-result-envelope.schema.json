{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "skill-result-envelope.schema.json",
  "title": "SkillResultEnvelope",
  "description": "所有活跃 Skill 的统一执行结果。领域数据放入 payload，事实结论必须回链 evidence_refs。",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "status", "summary", "findings", "evidence", "assumptions", "limitations", "recommendations", "payload"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "status": { "type": "string", "enum": ["succeeded", "degraded", "failed"] },
    "summary": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "confidence", "evidence_refs"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source_type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source_type": { "type": "string", "enum": ["tool_result", "kb", "user_material", "llm_inference"] },
          "trace_id": { "type": "string", "minLength": 1 },
          "source_ref": { "type": "string", "minLength": 1 }
        }
      }
    },
    "assumptions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "recommendations": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "payload": { "type": "object" }
  }
}

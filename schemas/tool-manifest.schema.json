{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tool-manifest.schema.json",
  "title": "ToolManifest",
  "description": "tool 执行边界声明。承载权限/超时/重试/脱敏/审批,但不写业务判断。字段对齐方案 §2.3。",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "name", "adapter_type", "auth_required", "risk_level", "input_schema", "output_schema"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "adapter_type": {
      "type": "string",
      "description": "调用通道。V0 只实现 o2/fake,其余留协议。",
      "enum": ["o2", "internal_api", "mcp", "script", "fake"]
    },
    "entrypoint": { "type": "string", "description": "adapter 入口,如 o2 命令。" },
    "auth_required": { "type": "boolean" },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "approver_rule": {
      "type": "string",
      "description": "审批规则。high risk 必须非 none(由 registry-linter 强制)。",
      "enum": ["none", "owner", "security", "legal"]
    },
    "timeout_seconds": { "type": "integer", "minimum": 1 },
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_attempts": { "type": "integer", "minimum": 1 },
        "backoff_seconds": { "type": "number", "minimum": 0 }
      }
    },
    "input_schema": { "type": "string", "minLength": 1 },
    "output_schema": { "type": "string", "minLength": 1 },
    "redaction_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pii": { "type": "string", "enum": ["mask", "block", "allow"] },
        "sensitive_business_data": { "type": "string", "enum": ["mask", "block", "allow"] }
      }
    }
  }
}

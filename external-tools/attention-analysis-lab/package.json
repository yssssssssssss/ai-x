{
  "name": "attention-analysis-lab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:server": "npm --workspace @attention-analysis-lab/server run dev",
    "dev:web": "npm --workspace @attention-analysis-lab/web run dev",
    "build": "npm run build --workspace @attention-analysis-lab/core --workspace @attention-analysis-lab/server --workspace @attention-analysis-lab/web",
    "typecheck": "npm run typecheck --workspace @attention-analysis-lab/core --workspace @attention-analysis-lab/server --workspace @attention-analysis-lab/web",
    "smoke": "node scripts/smoke.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.2"
  }
}

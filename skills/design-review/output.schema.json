{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "design-review/output.schema.json",
  "title": "DesignExperienceReviewOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["assessments", "priority_actions", "sources"],
  "properties": {
    "assessments": {
      "type": "array",
      "description": "各维度评估(美学/注意力/品牌)。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dimension", "finding", "source"],
        "properties": {
          "dimension": { "type": "string", "enum": ["aesthetic", "attention", "brand"] },
          "finding": { "type": "string", "minLength": 1 },
          "score": { "type": ["number", "null"] },
          "status": { "type": "string", "enum": ["available", "data_incomplete"] },
          "source": { "type": "string", "enum": ["tool_result", "llm_inference", "pending_human_review"] }
        }
      }
    },
    "priority_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "sources": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

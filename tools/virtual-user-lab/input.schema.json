{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "virtual-user-lab/input.schema.json",
  "title": "VirtualUserSimulateInput",
  "description": "虚拟用户模拟入参(POST /api/simulate,body 原样透传)。用数字人格评审产品/设计。",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "persona": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "goals": { "type": "array", "items": { "type": "string" } },
        "concerns": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "properties": {
    "scenario": { "type": "string" },
    "productDescription": { "type": "string" },
    "artifactText": { "type": "string" },
    "targetUserGroups": { "type": "array", "items": { "type": "string" } },
    "personaProfiles": { "type": "array", "items": { "$ref": "#/definitions/persona" } },
    "reviewDimensions": { "type": "array", "items": { "type": "string" } }
  }
}

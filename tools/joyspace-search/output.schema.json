{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "joyspace-search/output.schema.json",
  "title": "JoyspaceSearchOutput",
  "description": "JoySpace 检索输出。results 为命中文档/文件夹列表,字段原样透传自 webcli joyspace search。",
  "type": "object",
  "additionalProperties": true,
  "required": ["results"],
  "properties": {
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "rank": { "type": "integer" },
          "title": { "type": "string" },
          "type": { "type": "string", "description": "文档/文件夹/表格 等" },
          "author": { "type": "string" },
          "erp": { "type": "string" },
          "url": { "type": "string" },
          "scope": { "type": "string", "description": "与我相关/团队空间/全部公开" },
          "preview": { "type": "string", "description": "正文摘要" },
          "updated_at": { "type": "string" }
        }
      }
    }
  }
}

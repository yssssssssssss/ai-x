{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "experience-model-lab/output.schema.json",
  "title": "ExperienceModelOutput",
  "description": "体验模型匹配结果(原样透传)。",
  "type": "object",
  "additionalProperties": true,
  "required": ["status"],
  "properties": {
    "status": { "type": "string", "enum": ["available", "failed", "insufficient_inputs"] },
    "summary": { "type": "string" },
    "selectedModels": { "type": "array", "description": "命中的体验模型及理由/评分" },
    "rejectedModels": { "type": "array" },
    "frameworkSummary": { "type": "string" },
    "modelRationale": { "type": "array", "items": { "type": "string" } },
    "questionTemplates": { "type": "array", "items": { "type": "string" } },
    "evidenceChunks": { "type": "array" },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}

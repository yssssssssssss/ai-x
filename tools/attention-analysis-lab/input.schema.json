{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "attention-analysis-lab/input.schema.json",
  "title": "AttentionAnalysisInput",
  "description": "视觉注意力分析入参(POST /api/analyze,body 原样透传)。",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "imageRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "path": { "type": "string" },
        "url": { "type": "string" },
        "dataUrl": { "type": "string", "description": "data:image/*;base64,..." }
      }
    },
    "roi": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" }
      }
    }
  },
  "properties": {
    "image": { "$ref": "#/definitions/imageRef" },
    "rois": { "type": "array", "items": { "$ref": "#/definitions/roi" } },
    "mode": { "type": "string", "enum": ["heuristic", "semantic", "hybrid"] },
    "includeCenterBias": { "type": "boolean" }
  }
}

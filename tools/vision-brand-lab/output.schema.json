{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vision-brand-lab/output.schema.json",
  "title": "VisionBrandOutput",
  "description": "视觉品牌评审结果(原样透传)。",
  "type": "object",
  "additionalProperties": true,
  "required": ["status"],
  "properties": {
    "status": { "type": "string", "enum": ["available", "partial_failed", "failed", "insufficient_inputs"] },
    "summary": { "type": "string" },
    "engine": { "type": "string", "enum": ["vlm", "heuristic"] },
    "degraded": { "type": "boolean" },
    "reasonCode": { "type": "string", "enum": ["vlm_not_configured", "vlm_failed"] },
    "model": { "type": "string" },
    "attempts": { "type": "integer", "minimum": 0 },
    "visualReview": { "type": "object", "description": "多角色评审:reviewers/consensus/conflicts/priorityActions" },
    "brandAssociation": { "type": "object" },
    "findings": { "type": "array", "items": { "type": "string" } },
    "recommendations": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}
